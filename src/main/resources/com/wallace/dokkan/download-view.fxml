<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER_LEFT" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" spacing="15.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.wallace.dokkan.downloadController">
    <padding>
        <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
    </padding>
    <children>
        <Label text="Converter Youtube para MP3">
            <font>
                <Font name="System Bold" size="24.0" />
            </font>
        </Label>
        <Label text="Digite a URL do vídeo:">
            <font>
                <Font size="18.0" />
            </font>
        </Label>
        <TextField fx:id="txtUrl" promptText="Cole o link aqui..." />
        <Button mnemonicParsing="false" onAction="#onDownloadButtonClick" prefHeight="30.0" prefWidth="100.0" text="Baixar" />
        <ProgressBar fx:id="progressDownload" prefHeight="20.0" prefWidth="552.0" progress="0.0" />
      <Label fx:id="lblStatus" />
    </children>
</VBox>
